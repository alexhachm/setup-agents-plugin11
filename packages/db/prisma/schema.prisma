generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── NextAuth tables ──

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Core entities ──

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String            @unique
  emailVerified    DateTime?
  image            String?
  createdAt        DateTime          @default(now())
  accounts         Account[]
  sessions         Session[]
  ownedWorkspaces  Workspace[]       @relation("WorkspaceOwner")
  memberships      WorkspaceMember[]
  createdNotebooks Notebook[]
  createdNotes     Note[]
  sharingLinks     SharingLink[]
  snapshots        Snapshot[]
}

model Workspace {
  id            String            @id @default(cuid())
  name          String
  ownerId       String
  plan          WorkspacePlan     @default(free)
  creditBalance Int               @default(0)
  createdAt     DateTime          @default(now())
  owner         User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members       WorkspaceMember[]
  notebooks     Notebook[]
}

model WorkspaceMember {
  workspaceId String
  userId      String
  role        WorkspaceRole @default(editor)
  creditShare Int?
  invitedAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
}

model Notebook {
  id             String           @id @default(cuid())
  workspaceId    String
  title          String
  icon           String           @default("📓")
  domain         String?
  order          Int              @default(0)
  status         NotebookStatus   @default(active)
  visibilityTier GranularityLevel @default(beginner)
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy      User             @relation(fields: [createdById], references: [id])
  notes          Note[]
  sharingLinks   SharingLink[]    @relation("NotebookSharing")
}

model Note {
  id             String           @id @default(cuid())
  notebookId     String
  title          String
  yjsDocId       String           @unique @default(cuid())
  status         NoteStatus       @default(idea)
  tags           String[]         @default([])
  order          Int              @default(0)
  visibilityTier GranularityLevel @default(beginner)
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  notebook       Notebook         @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  createdBy      User             @relation(fields: [createdById], references: [id])
  snapshots      Snapshot[]
  sharingLinks   SharingLink[]    @relation("NoteSharing")
}

model SharingLink {
  id           String          @id @default(cuid())
  resourceType ResourceType
  resourceId   String
  permission   SharePermission @default(view)
  token        String          @unique @default(cuid())
  createdById  String
  createdAt    DateTime        @default(now())
  createdBy    User            @relation(fields: [createdById], references: [id])
  notebook     Notebook?       @relation("NotebookSharing", fields: [resourceId], references: [id], map: "SharingLink_notebook_fkey")
  note         Note?           @relation("NoteSharing", fields: [resourceId], references: [id], map: "SharingLink_note_fkey")
}

model Snapshot {
  id          String          @id @default(cuid())
  noteId      String
  trigger     SnapshotTrigger @default(auto)
  description String          @default("")
  createdById String
  createdAt   DateTime        @default(now())
  yjsState    Bytes
  note        Note            @relation(fields: [noteId], references: [id], onDelete: Cascade)
  createdBy   User            @relation(fields: [createdById], references: [id])
}

// Yjs document state persistence for Hocuspocus
model YjsDocument {
  name      String   @id
  data      Bytes
  updatedAt DateTime @updatedAt
}

// ── Enums ──

enum WorkspacePlan {
  free
  pro
  team
}

enum WorkspaceRole {
  owner
  admin
  editor
  viewer
  suggestion_only
}

enum NotebookStatus {
  draft
  active
  archived
}

enum NoteStatus {
  idea
  planned
  in_progress
  implemented
  tested
  broken
}

enum GranularityLevel {
  beginner
  intermediate
  advanced
}

enum ResourceType {
  workspace
  notebook
  note
}

enum SharePermission {
  view
  comment
  edit
  suggestion_only
}

enum SnapshotTrigger {
  manual
  auto
  ai_change
  timer
}
