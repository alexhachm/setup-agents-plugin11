{
  "name": "@plugin11/ai-engine",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "plugin11": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@hocuspocus/provider": "^2.15.0",
    "@plugin11/shared": "workspace:*",
    "pdf-parse": "^2.4.5",
    "yjs": "^13.6.24"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "moduleNameMapper": {
      "^@plugin11/shared$": "<rootDir>/../packages/shared/src/index.ts"
    }
  }
}
